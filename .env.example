# Required
ANTHROPIC_API_KEY=sk-ant-...

# GCP
GCP_PROJECT=claude-connectors
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/sa-key.json

# Agent config overrides
AGENT_CONFIG_AGENT__NAME=my-agent
AGENT_CONFIG_AGENT__MODEL=claude-sonnet-4-6

# Server
PORT=8080
PUBLIC_URL=http://localhost:8080

# OAuth (auto-generated by make setup-infra)
OAUTH_CLIENT_CREDENTIALS=
OAUTH_SIGNING_KEY=

# Optional
AGENT_CONFIG_A2A__ENABLED=true
